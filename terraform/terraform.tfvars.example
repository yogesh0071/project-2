# Copy this file to terraform.tfvars and fill in your real values.
# terraform.tfvars is where your actual secrets/specifics go - never commit it to git.

aws_region    = "ap-south-1"
project_name  = "devops-demo"
instance_type = "t3.small"

# Must be an EXISTING key pair name in your AWS account (EC2 > Key Pairs).
# If you don't have one, create it in the AWS console first and download the .pem file.
key_pair_name = "devops-demo-key"

# Get your current public IP from https://whatismyip.com and add /32
my_ip = "223.185.39.200/32"
