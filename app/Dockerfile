FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app.py .

EXPOSE 5000

# gunicorn instead of flask dev server - dev server is not meant for anything
# resembling production, even a demo project should not use it
CMD ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "2", "app:app"]
